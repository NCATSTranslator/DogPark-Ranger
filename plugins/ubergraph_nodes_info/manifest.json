{
    "version": "0.2",
    "requires": [
        "jsonlines"
    ],
    "dumper": {
        "data_url": [
            "https://kgx-storage.rtx.ai/releases/ubergraph/latest/ubergraph.tar.zst"
        ],
        "uncompress": false,
        "release": "hub.dataload.metadata_parser:get_kgx_release"
    },
    "uploaders": [
        {
            "name": "ubergraph_nodes_info",
            "parser": "hub.dataload.kg_loader:node_info_parser",
            "parser_kwargs": {
                "adj_list_key": "mapping",
                "should_reverse": true
            },
            "on_duplicates": "error",
            "mapping": "hub.dataload.mapping.info_mapping:info_mapping"
        }
    ]
}